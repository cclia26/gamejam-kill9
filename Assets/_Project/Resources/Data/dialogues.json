      "triggerCondition": "c1_2",
      "triggerEnterCount": -1,
      "priority": 10,
      "onComplete": "c1_3",
      "playOnce": true,
      "text": "今天是20xx年xx月xx日，晚上xx:xx。你已经连续工作了16个小时。"
