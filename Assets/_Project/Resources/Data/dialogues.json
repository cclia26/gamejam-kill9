      "id": "chat_unexplored_2",
      "speaker": "",
      "delay": 1.0,
      "triggerScene": "Desktop",
      "triggerCondition": "cu1_2",
      "triggerEnterCount": -1,
      "priority": 10,
      "onComplete": "cu1_3",
      "playOnce": true,
