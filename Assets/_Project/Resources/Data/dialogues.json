      "delay": 1.2,
      "triggerScene": "Desktop",
      "triggerCondition": "c1_5",
      "triggerEnterCount": -1,
      "priority": 10,
      "onComplete": "chat_started",
      "playOnce": true,
      "text": "我认得你的登录凭证。好久不见。"
