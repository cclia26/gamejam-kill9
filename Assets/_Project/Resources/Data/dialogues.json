      "speaker": "",
      "delay": 1.0,
      "triggerScene": "Desktop",
      "triggerCondition": "chat_first_unexplored_repeat",
      "triggerEnterCount": -1,
      "priority": 10,
      "onComplete": "cu1_2",
      "playOnce": true,
      "text": "你进来之后什么都没碰。"
