      "triggerScene": "Desktop",
      "triggerCondition": "chat_first_unexplored",
      "triggerEnterCount": -1,
      "priority": 10,
      "onComplete": "c1_2",
      "playOnce": true,
      "text": "你好，我是普罗米修斯，你的专属AI助手。"
